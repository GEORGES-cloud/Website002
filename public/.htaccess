# =====================================================================
# Zeñorío · configuración para hosting estático (Hostinger · Apache/LiteSpeed)
# Sube el CONTENIDO de esta carpeta (public/) a public_html.
# =====================================================================

# --- Página de inicio y errores -------------------------------------
DirectoryIndex index.html
# Rutas/recursos inexistentes → página 404 propia con estado 404 real
# (evita los "soft 404" que penaliza Google al devolver 200 con la home).
ErrorDocument 404 /404.html

# --- HTTPS y dominio canónico ----------------------------------------
# Dominio canónico: zenorio.es. El antiguo zeñorio.com (xn--zeorio-xwa.com)
# redirige con 301 conservando la ruta. Después: todo a https:// y sin www.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_HOST} ^(www\.)?xn--zeorio-xwa\.com$ [NC]
  RewriteRule ^ https://zenorio.es%{REQUEST_URI} [R=301,L]
  RewriteCond %{HTTP_HOST} ^www\.zenorio\.es$ [NC]
  RewriteRule ^ https://zenorio.es%{REQUEST_URI} [R=301,L]
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]
</IfModule>

# --- WebP automático: sirve la versión .webp si el navegador la acepta
# y existe el gemelo .webp junto al .jpg (más ligero, sin tocar el HTML).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_ACCEPT} image/webp
  RewriteCond %{REQUEST_FILENAME} (.+)\.(jpe?g)$
  RewriteCond %1.webp -f
  RewriteRule (.+)\.(jpe?g)$ $1.webp [T=image/webp,E=accept:1,L]
</IfModule>

# --- Compresión -----------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml \
    application/javascript application/json image/svg+xml application/xml
</IfModule>

# --- Caché ----------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  # HTML: sin caché larga (se publican los cambios al instante).
  ExpiresByType text/html            "access plus 0 seconds"
  # CSS/JS: versionados con ?v=N → caché de un año (este hosting sirve el
  # JS como application/x-javascript, por eso van los dos tipos).
  ExpiresByType text/css             "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/x-javascript "access plus 1 year"
  # Binarios estables: caché de un año.
  ExpiresByType image/jpeg           "access plus 1 year"
  ExpiresByType image/png            "access plus 1 year"
  ExpiresByType image/webp           "access plus 1 year"
  ExpiresByType image/svg+xml        "access plus 1 year"
  ExpiresByType video/mp4            "access plus 1 year"
  ExpiresByType font/woff2           "access plus 1 year"
</IfModule>

# --- Cabeceras ------------------------------------------------------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  # HSTS: el sitio es https-only (http hace 301); un año, con subdominios.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header append Vary Accept env=accept
  # Caché larga para binarios estables Y para css/js: van versionados con
  # ?v=N y la versión se sube en cada cambio (disciplina del repo), así que
  # pueden ser immutable sin riesgo de servir código viejo.
  <FilesMatch "\.(jpg|jpeg|png|webp|svg|mp4|woff2|css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # El HTML siempre se revalida (publica los cambios al instante).
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
